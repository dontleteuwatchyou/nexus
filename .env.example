# Create a free subdomain at https://www.duckdns.org/
DUCKDNS_SUBDOMAIN=your-nexus-name
DUCKDNS_TOKEN=replace-with-your-duckdns-token

# Login used by the self-hosted Web Lab (minimum 8 characters for password).
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=replace-with-a-long-unique-password
# Optional JSON object. Keep real credentials in .env only.
NEXUS_ADDITIONAL_USERS={}

# Generate with: openssl rand -hex 32
NEXUS_SESSION_SECRET=replace-with-at-least-64-random-hex-characters

# Optional API keys consumed by existing Nexus modules.
GH_TOKEN=
OSINT_DEFAULT_REGION=BE
